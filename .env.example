# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug
SERVER_BASE_URL=http://localhost:8080

# Database (sqlite, postgres, mysql)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=vortexcms
DB_PASSWORD=
DB_NAME=vortexcms
DB_SSL_MODE=disable

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Redis (optional, for production blacklist/cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=vortex:

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_STORAGE_PATH=./uploads
UPLOAD_URL_PREFIX=/uploads

# Admin password (generated on first run if not set)
ADMIN_PASSWORD=

# Rate limiting
AUTH_RATE_LIMIT=10
API_RATE_LIMIT=100

# Log
LOG_LEVEL=info
LOG_FORMAT=json
